<body>

  <!-- Bot Gopal -->
  <div id="chat-icon" onclick="toggleChat()">
    <span id="chat-icon-text" style="color: white; font-size: 24px;">🤖</span> <!-- Updated icon text -->
  </div>

  <div id="chat-container">
    <div id="header">
      <h3 style="margin: 0;">Gopal Tiwari</h3>
      <div id="language">
        <img id="language-icon" src="/Images/Home/languages.png" onclick="toggleLanguageSelector()" />
        <select id="language-selector" onchange="changeLanguage()">
          <option value="en">🇬🇧 English</option>
          <option value="hi">🇮🇳 हिन्दी</option>
          <option value="es">🇪🇸 Español</option>
        </select>
      </div>
    </div>

    <div id="chat-box"></div>
    <input type="text" id="user-input" onkeypress="checkEnter(event)" placeholder="Type your message...">
    <button id="send-button" onclick="sendMessage()">Send</button>
  </div>
  <!-- Bot end -->



  <!-- Header / Navbar -->
